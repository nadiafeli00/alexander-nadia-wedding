# Google Apps Script Integration
NEXT_PUBLIC_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/d/YOUR_SCRIPT_ID/usercontent/dev

# Optional: Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Database (if using external service)
DATABASE_URL=

# Node Environment
NODE_ENV=production
